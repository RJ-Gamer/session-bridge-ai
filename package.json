{
  "name": "session-bridge-ai",
  "displayName": "Session Bridge AI",
  "publisher": "RajatJog",
  "description": "Persistent AI session context across tools",
  "version": "0.0.1",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "session-bridge.saveNow",
        "title": "Session Bridge: Save Context Now"
      },
      {
        "command": "session-bridge.logMessage",
        "title": "Session Bridge: Log Message"
      },
      {
        "command": "session-bridge.setApiKey",
        "title": "Session Bridge: Set Gemini API Key"
      },
      {
        "command": "session-bridge.clearBuffer",
        "title": "Session Bridge: Clear Buffer"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.15.1"
  }
}
